<div class="modal fade" id="modalAdd" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title">Registrar Movimiento</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="formAdd">
                    <div class="mb-3">
                        <label class="form-label fw-bold">Producto</label>
                        <select class="form-select" id="cboProductoAdd" required></select>
                        <div id="stockInfoAdd" class="form-text text-info fw-bold"></div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Tipo</label>
                        <select class="form-select" id="cboTipoAdd" required>
                            <option value="Entrada">Entrada</option>
                            <option value="Salida">Salida</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Cantidad</label>
                        <input type="number" class="form-control" id="txtCantidadAdd" min="1" required>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cerrar</button>
                <button type="button" id="btnGuardarNuevo" class="btn btn-primary">Guardar</button>
            </div>
        </div>
    </div>
</div>