@{
    ViewData["Title"] = "Gestión de Usuarios";
    Layout = "~/Views/Shared/_Layout.cshtml";
}


<div class="card shadow-sm">
    <div class="card-header d-flex justify-content-between align-items-center">
       
        <span class="fw-bold fs-5">
            <i class="fa-solid fa-users me-2"></i> Gestión de Usuarios
        </span>
        
        <button class="btn btn-primary" onclick="abrirModalRegistro()">
            <i class="fa-solid fa-user-plus me-1"></i> Agregar Usuario
        </button>
    </div>

    <div class="card-body">
        <div class="table-responsive">           
            <table id="tbUsuarios" class="table table-striped table-hover align-middle w-100">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>NOMBRE</th>
                        <th>CORREO</th>
                        <th>ROL</th>
                        <th class="text-center">ACCIONES</th>
                    </tr>
                </thead>
                <tbody>                   
                </tbody>
            </table>
        </div>
    </div>
</div>


@await Html.PartialAsync("~/Views/Usuario/Modals/AddModel.cshtml")
@await Html.PartialAsync("~/Views/Usuario/Modals/UpdateModel.cshtml")

@section Scripts {
    <script src="~/js/vistas/Usuario_Index.js" asp-append-version="true"></script>
}