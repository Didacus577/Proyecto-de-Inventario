@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h1>Dashboard</h1>

<div style="display:flex; justify-content: space-around; margin-top: 30px;">
    <div>
        <h3>Productos con más salida</h3>
        <canvas id="productosSalida" width="400" height="300"></canvas>
    </div>
    <div>
        <h3>Productos con más entrada</h3>
        <canvas id="productosEntrada" width="400" height="300"></canvas>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="~/js/vistas/Dashboard.js"></script>
}
