@{
    ViewData["Title"] = "Gestión de Proveedores";
    Layout = "~/Views/Shared/_Layout.cshtml";
}


<div class="card shadow-sm">
    <div class="card-header d-flex justify-content-between align-items-center">
      
        <span class="fw-bold fs-5">
            <i class="fa-solid fa-truck me-2"></i> Gestión de Proveedores
        </span>
        
        <button id="btnNuevo" class="btn btn-primary">
            <i class="fa-solid fa-plus me-1"></i> Agregar Proveedor
        </button>
    </div>

    <div class="card-body">
        <div class="table-responsive">
           
            <table id="tbProveedor" class="table table-striped table-hover align-middle w-100">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>NOMBRE</th>
                        <th>TELÉFONO</th>
                        <th>CORREO</th>
                        <th>DIRECCIÓN</th>
                        <th class="text-center">ACCIONES</th>
                    </tr>
                </thead>
                <tbody>
                   
                </tbody>
            </table>
        </div>
    </div>
</div>


@await Html.PartialAsync("~/Views/Proveedor/Modals/AddModel.cshtml")
@await Html.PartialAsync("~/Views/Proveedor/Modals/UpdateModal.cshtml")

@section Scripts {
    <script src="~/js/vistas/Proveedor_Index.js" asp-append-version="true"></script>
}