@{
    ViewData["Title"] = "Reporte";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h1>Reporte de Movimientos de Inventario - Últimos 7 días</h1>

<p>Este reporte muestra los productos que han tenido entradas y salidas en los últimos 7 días.</p>

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Producto</th>
            <th>Tipo de Movimiento</th>
            <th>Cantidad</th>
            <th>Fecha</th>
        </tr>
    </thead>
    <tbody>
        @* Datos quemados de ejemplo *@
        <tr>
            <td>Producto A</td>
            <td>Entrada</td>
            <td>20</td>
            <td>@DateTime.Now.AddDays(-1).ToShortDateString()</td>
        </tr>
        <tr>
            <td>Producto B</td>
            <td>Salida</td>
            <td>15</td>
            <td>@DateTime.Now.AddDays(-2).ToShortDateString()</td>
        </tr>
        <tr>
            <td>Producto C</td>
            <td>Entrada</td>
            <td>30</td>
            <td>@DateTime.Now.AddDays(-3).ToShortDateString()</td>
        </tr>
        <tr>
            <td>Producto D</td>
            <td>Salida</td>
            <td>10</td>
            <td>@DateTime.Now.AddDays(-5).ToShortDateString()</td>
        </tr>
    </tbody>
</table>

<form asp-action="GenerarPDF" method="post">
    <button type="submit" class="btn btn-primary">Generar PDF</button>
</form>

@section Scripts {
    <script>
        // Aquí podrías agregar alguna lógica para filtros antes de generar PDF si quieres
    </script>
}
