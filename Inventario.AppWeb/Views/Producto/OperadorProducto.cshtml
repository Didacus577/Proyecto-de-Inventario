@{
    ViewData["Title"] = "Inventario de Productos - Operador";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="card shadow-sm">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span class="fw-bold fs-5">
            <i class="fa-solid fa-box-open me-2"></i> Inventario de Productos (Operador)
        </span>
        <div>
            <button class="btn btn-danger me-2" onclick="descargarReportePDF()" title="Exportar a PDF">
                <i class="fa-solid fa-file-pdf me-1"></i> Exportar PDF
            </button>

            <button class="btn btn-primary" onclick="abrirModalRegistro()">
                <i class="fa-solid fa-plus me-1"></i> Agregar Producto
            </button>
        </div>
    </div>

    <div class="card-body">
        <div class="card bg-light border-0 mb-4">
            <div class="card-body p-3">
                <div class="row align-items-end g-2">
                    <div class="col-12 col-md-4">
                        <label class="form-label fw-bold text-muted small"><i class="fa-solid fa-tags me-1"></i> Categoría</label>
                        <select id="filtroCategoria" class="form-select form-select-sm">
                            <option value="">Todas las categorías</option>
                        </select>
                    </div>
                    <div class="col-12 col-md-4">
                        <label class="form-label fw-bold text-muted small"><i class="fa-solid fa-copyright me-1"></i> Marca</label>
                        <select id="filtroMarca" class="form-select form-select-sm">
                            <option value="">Todas las marcas</option>
                        </select>
                    </div>
                    <div class="col-12 col-md-3">
                        <label class="form-label fw-bold text-muted small"><i class="fa-solid fa-toggle-on me-1"></i> Estado</label>
                        <select id="filtroEstado" class="form-select form-select-sm">
                            <option value="">Todos los estados</option>
                            <option value="Activo">Activo</option>
                            <option value="Inactivo">Inactivo</option>
                        </select>
                    </div>
                    <div class="col-12 col-md-1 text-end">
                        <button id="btnLimpiarFiltros" class="btn btn-sm btn-outline-secondary w-100" title="Limpiar Filtros">
                            <i class="fa-solid fa-broom"></i>
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <div class="table-responsive">
            <table id="tbProductos" data-rol="operador" class="table table-striped table-hover align-middle w-100">
                <thead>
                    <tr>
                        <th>NOMBRE</th>
                        <th>CATEGORÍA</th>
                        <th>MARCA</th>
                        <th>STOCK</th>
                        <th>ESTADO</th>
                        <th class="text-center">ACCIONES</th>
                    </tr>
                </thead>
                <tbody>                 
                </tbody>
            </table>
        </div>
    </div>
</div>


@await Html.PartialAsync("~/Views/Producto/Modals/AddModel.cshtml")
@await Html.PartialAsync("~/Views/Producto/Modals/UpdateModel.cshtml")
@await Html.PartialAsync("~/Views/Producto/Modals/viewModel.cshtml")

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
    
    <script src="~/js/Productos_reportes.js" asp-append-version="true"></script>
    
    <script src="~/js/vistas/Productos_index.js" asp-append-version="true"></script>
}